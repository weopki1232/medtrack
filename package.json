{
  "name": "medtrack",
  "version": "1.0.0",
  "description": "TCAS Medical School Study Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.medtrack.tcas",
    "productName": "MedTrack",
    "copyright": "Thanachart",
    "files": [
      "main.js",
      "medtrack.html",
      "icon.ico"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MedTrack"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
